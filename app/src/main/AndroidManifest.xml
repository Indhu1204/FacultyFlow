<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FacultyFlow">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FacultyFlow.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />

        <activity
            android:name=".SignupActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".faculty.FacultyHomeActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".faculty.TimetableUploadActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".faculty.BookingInboxActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".faculty.ProfileEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".student.FacultyDirectoryActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".student.FacultyProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".student.BookSlotActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
        
        <activity
            android:name=".student.MyBookingsActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />

        <activity
            android:name=".student.StudentProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.FacultyFlow.NoActionBar" />
            
    </application>

</manifest>