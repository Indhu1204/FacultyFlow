<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FacultyFlow" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/apple_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/apple_secondary_background</item>
        <item name="colorOnPrimaryContainer">@color/apple_blue</item>

        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/apple_gray</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/apple_background</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Background colors -->
        <item name="android:windowBackground">@color/apple_background</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/apple_background</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="textAppearanceTitleLarge">@style/TextAppearance.App.TitleLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.App.BodyMedium</item>
    </style>

    <style name="Theme.FacultyFlow.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Typography -->
    <style name="TextAppearance.App.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/apple_label</item>
    </style>

    <style name="TextAppearance.App.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/apple_secondary_label</item>
    </style>

    <!-- Apple Style Components -->
    <style name="AppleCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/apple_card</item>
    </style>

    <style name="AppleButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="AppleButton.Green">
        <item name="backgroundTint">@color/ios_green</item>
    </style>

    <style name="AppleButton.Red">
        <item name="backgroundTint">@color/ios_red</item>
    </style>

    <style name="AppleButton.Yellow">
        <item name="backgroundTint">@color/ios_yellow</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="AppleEditText" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/ios_blue</item>
        <item name="hintTextColor">@color/ios_blue</item>
    </style>

    <!-- Unified Styles (Combining styles.xml and themes.xml) -->
    <style name="AppleCardView" parent="AppleCard" />
    
    <style name="AppleButtonPrimary" parent="AppleButton">
        <item name="android:backgroundTint">@color/apple_blue</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="AppleButtonSecondary" parent="AppleButton">
        <item name="android:backgroundTint">@color/apple_light_gray</item>
        <item name="android:textColor">@color/apple_blue</item>
        <item name="android:textStyle">normal</item>
    </style>
    
    <style name="AppleTextInputLayoutStyle" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/apple_light_gray</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintTextColor">@color/apple_gray</item>
        <item name="android:textColorHint">@color/apple_gray</item>
    </style>

    <style name="AppleEditTextStyle" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/apple_label</item>
    </style>

</resources>
