<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppleCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvStartTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/apple_label"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvEndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00"
                android:textColor="@color/apple_tertiary_label"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="@color/ios_blue" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvClassName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data Structures"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/apple_label"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/tvClassRoom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Room 301 • Block A"
                android:textColor="@color/apple_secondary_label"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BUSY"
            android:textColor="@color/ios_red"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
