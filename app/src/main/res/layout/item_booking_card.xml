<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppleCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:orientation="horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivFacultyAvatar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvFacultyName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dr. John Smith"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/apple_label"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvBookingTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Oct 24 • 2:00 PM - 2:30 PM"
                    android:textColor="@color/apple_secondary_label"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="6dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ios_gray6">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="PENDING"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/ios_orange" />
            </com.google.android.material.card.MaterialCardView>

            <ImageView
                android:id="@+id/ivExpand"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_more"
                app:tint="@color/ios_gray3" />
        </LinearLayout>

        <!-- Expanded details -->
        <LinearLayout
            android:id="@+id/expandedSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ios_gray6"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR NOTE"
                android:textColor="@color/apple_tertiary_label"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvStudentNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Discussing the project architecture."
                android:textColor="@color/apple_label"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/facultyReplySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FACULTY REPLY"
                    android:textColor="@color/apple_tertiary_label"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvFacultyReply"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Looking forward to it."
                    android:textColor="@color/ios_blue"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
